# =============================================================================
# SECURITY SETTINGS (REQUIRED)
# =============================================================================

# Generate a strong secret key using:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-very-strong-secret-key-here-change-this-in-production

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
# Production: himawatkhandavastu.com,www.himawatkhandavastu.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of CSRF trusted origins (for production)
# CSRF_TRUSTED_ORIGINS=https://himawatkhandavastu.com,https://www.himawatkhandavastu.com


# =============================================================================
# DATABASE SETTINGS
# =============================================================================

# SQLite (Development)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL (Production) - Uncomment to use
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=negeobag_himawat
# DB_USER=negeobag_himawat
# DB_PASSWORD=your-strong-password-here
# DB_HOST=127.0.0.1
# DB_PORT=5432

# MySQL (Alternative Production) - Uncomment to use
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=negeobag_himawat
# DB_USER=negeobag_himawat
# DB_PASSWORD=your-strong-password-here
# DB_HOST=127.0.0.1
# DB_PORT=3306


# =============================================================================
# SITE SETTINGS
# =============================================================================

SITE_NAME=Himwatkhanda Vastu Pvt. Ltd.
SITE_DESCRIPTION=Your Blueprint for Harmony, Structure, and Expertise
SITE_URL=https://himawatkhandavastu.com

# Admin email for notifications
ADMIN_EMAIL=admin@himawatkhandavastu.com


# =============================================================================
# EMAIL SETTINGS (Optional)
# =============================================================================

# For development, emails are printed to console by default

# For production SMTP (e.g., Gmail, SendGrid, AWS SES)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@himawatkhandavastu.com
# SERVER_EMAIL=server@himawatkhandavastu.com
