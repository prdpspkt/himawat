# =============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT FILE
# =============================================================================
# This file contains local development settings with DEBUG=True.
# Safe to commit as it uses development defaults.
# =============================================================================

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Development secret key (you can change this if needed)
DJANGO_SECRET_KEY=django-insecure-wnx+#tn3lti*sz@3un)lrl-i6d*ilfzkg##z1&ip@gpgmt8f$4

# DEBUG=True enables development features:
# - Detailed error pages
# - Debug toolbar
# - Auto-reload on code changes
# - Console email backend
DEBUG=True

# Local development hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF trusted origins for local development
# Note: Include http:// for local development without HTTPS
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000


# =============================================================================
# DATABASE SETTINGS (SQLite for Local Development)
# =============================================================================

# SQLite is perfect for local development - no server required
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Alternative: Use MySQL locally (uncomment to match production setup)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=himawat_local_db
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306

# Alternative: Use PostgreSQL locally (uncomment to match production setup)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=himawat_local_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432


# =============================================================================
# SITE SETTINGS
# =============================================================================

SITE_NAME=Himwatkhanda Vastu (Local Dev)
SITE_DESCRIPTION=Your Blueprint for Harmony, Structure, and Expertise
SITE_URL=http://localhost:8000

# Admin email for notifications
ADMIN_EMAIL=admin@localhost.com


# =============================================================================
# EMAIL SETTINGS (Console Backend for Development)
# =============================================================================

# Console backend prints emails to the terminal - perfect for development
# No actual emails are sent
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@localhost
SERVER_EMAIL=server@localhost


# =============================================================================
# LOCAL DEVELOPMENT NOTES
# =============================================================================
# To use this file instead of .env:
#
# Method 1: Rename to .env (recommended for local development)
#   - Rename this file from .env-local to .env
#   - Make sure to rename the production .env to .env-production first
#
# Method 2: Load explicitly in settings.py
#   - Modify settings.py to load .env-local when DEBUG=True
#
# Method 3: Pass via command line
#   - python manage.py runserver --env-file=.env-local
#
# Remember:
# - Never use DEBUG=True in production
# - Never commit production .env file
# - Use strong passwords in production
# - Keep your secret keys secure
